# ============================================================
# devdocs-forge-agent — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- Provider Selection ---
# Choose which AI provider to use. Default: mock (no API key needed)
# Options: mock | openai | anthropic | gemini
DEVDOCS_PROVIDER=mock

# --- Output & Config ---
DEVDOCS_OUTPUT_DIR=output
DEVDOCS_CONFIG=config/devdocs-forge-agent.yml

# --- OpenAI ---
# Required only if DEVDOCS_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# --- Anthropic ---
# Required only if DEVDOCS_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# --- Google Gemini ---
# Required only if DEVDOCS_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- YouTube Data API (optional) ---
# Required only for full video metadata validation (title, category, tags, duration)
# Without this, video URL classification uses title/URL heuristics only
# Get a key at https://console.cloud.google.com/ (enable YouTube Data API v3)
# Referhttps://github.com/kieraneglin/pinchflat/wiki/Generating-a-YouTube-API-key
YOUTUBE_API_KEY=
